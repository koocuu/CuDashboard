# ===== 数据库 =====
# Neon Postgres 连接串,通常需要 sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ===== 鉴权 =====
# 登录密码的 bcrypt 哈希。生成方式:npm run hash -- 你的明文密码
AUTH_PASSWORD_HASH="$2a$10$replace_with_your_bcrypt_hash"
# JWT 签名密钥。生产环境建议使用 32 位以上随机字符串
JWT_SECRET="replace_with_a_long_random_secret"
# 展示用户名,用于画像头部等位置
USER_NAME="开发者"

# ===== GitHub 每日备份 =====
# 具备目标私有仓库写权限的 PAT
GITHUB_BACKUP_TOKEN=""
# 形如 owner/repo
GITHUB_BACKUP_REPO=""
# 备份目标分支
GITHUB_BACKUP_BRANCH="main"
# 保护 /api/cron/backup 的密钥。Vercel Cron 请求头:Authorization: Bearer <此值>
CRON_SECRET=""
